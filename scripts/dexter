#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
python_bin="${DEXTER_PYTHON:-$repo_root/.venv/bin/python}"

if [[ ! -x "$python_bin" ]]; then
  echo "Dexter Python was not found at $python_bin." >&2
  echo "Create the environment with: python3.11 -m venv .venv && .venv/bin/pip install -e ." >&2
  exit 2
fi

workflow="${1:-}"
if [[ -z "$workflow" ]]; then
  echo "Usage: scripts/dexter <workflow> <command> [options]" >&2
  echo "Workflows: catalyst-center, mist, github, servicenow-query, servicenow-dns, servicenow-csv-dns, servicenow-network-gear" >&2
  exit 2
fi
shift

case "$workflow" in
  catalyst-center) skill="catalyst-center" ;;
  mist|juniper-mist) skill="juniper-mist" ;;
  github|github-explorer) skill="github-explorer" ;;
  servicenow-query) skill="servicenow-query" ;;
  servicenow-dns) skill="servicenow-dns" ;;
  servicenow-csv-dns) skill="servicenow-csv-dns" ;;
  servicenow-network-gear) skill="servicenow-network-gear" ;;
  *)
    echo "Unknown Dexter workflow: $workflow" >&2
    exit 2
    ;;
esac

handler="$repo_root/.agents/skills/dexter/skills/$skill/scripts/handler.py"
exec "$python_bin" "$handler" "$@"
