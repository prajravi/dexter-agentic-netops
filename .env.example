# Copy this file to .env at the repository root and provide local credentials.
# Alternatively, set DEXTER_ENV_FILE to an absolute path outside the repository.

# Cisco Catalyst Center
CATC_CONTROLLER=catalyst-center.example.com
CATC_USERNAME=administrator
CATC_PASSWORD=replace-with-your-password

# GitHub (the token is optional for public repositories)
# All GitHub requests are restricted to this configured owner.
GITHUB_OWNER=your-github-owner
GITHUB_TOKEN=

# ServiceNow instance. The URL hostname must exactly match the allowlist value.
SERVICENOW_DEV_INSTANCE=https://your-development-instance.service-now.com
SERVICENOW_ALLOWED_HOST=your-development-instance.service-now.com
SERVICENOW_DEV_USERNAME=admin
SERVICENOW_DEV_PASSWORD=replace-with-your-development-instance-password
